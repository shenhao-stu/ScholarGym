  "checkpoint_rebuild_simple": [
    {
      "id": "basic_simple",
      "cached_result": {
        "idx": 0,
        "ground_truth_arxiv_ids": ["gt1", "gt2"],
        "top_results": [
          {"arxiv_id": "gt1"},
          {"arxiv_id": "noise"},
          {"arxiv_id": "gt2"}
        ]
      },
      "top_k_list": [2],
      "expected": {
        "successful_queries": 1,
        "recall@2": [0.5],
        "precision@2": [0.5]
      }
    },
    {
      "id": "multiple_k_values",
      "cached_result": {
        "idx": 0,
        "ground_truth_arxiv_ids": ["gt1", "gt2", "gt3"],
        "top_results": [
          {"arxiv_id": "gt1"},
          {"arxiv_id": "noise1"},
          {"arxiv_id": "gt2"},
          {"arxiv_id": "noise2"},
          {"arxiv_id": "gt3"}
        ]
      },
      "top_k_list": [1, 3, 5],
      "expected": {
        "successful_queries": 1,
        "recall@1": [0.3333],
        "recall@3": [0.6667],
        "recall@5": [1.0]
      }
    }
  ]
}
